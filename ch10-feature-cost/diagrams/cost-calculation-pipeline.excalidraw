    {"type":"text","id":"stats_t","x":358,"y":330,"width":324,"height":58,"text":"Stats & Analytics (src/utils/stats.ts):\n  DailyActivity → GitHub-style heatmap\n  StreakInfo → gamification (consecutive days)\n  OTEL tracing → causal relationship spans\n  Perfetto export → chrome://tracing analysis\n  statsCache → incremental recomputation","originalText":"Stats & Analytics (src/utils/stats.ts):\n  DailyActivity → GitHub-style heatmap\n  StreakInfo → gamification (consecutive days)\n  OTEL tracing → causal relationship spans\n  Perfetto export → chrome://tracing analysis\n  statsCache → incremental recomputation","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":9503,"version":1,"versionNonce":9504,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"stats_box","lineHeight":1.25},

