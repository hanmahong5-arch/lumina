    {"type":"text","id":"pricing_t","x":28,"y":250,"width":294,"height":140,"text":"Pricing Tiers (12+ tiers):\nModel        Input   Output\n─────────────────────────────────\nHaiku 3.5    $0.80   $4.00\nSonnet 4     $3.00   $15.00\nOpus 4       $15.00  $75.00\nOpus 4 Fast  $30.00  $150.00\n\nCached (90% discount):\nHaiku cached $0.08   Sonnet cached $0.30\nOpus cached  $1.50   + cache_write tokens","originalText":"Pricing Tiers (12+ tiers):\nModel        Input   Output\n─────────────────────────────────\nHaiku 3.5    $0.80   $4.00\nSonnet 4     $3.00   $15.00\nOpus 4       $15.00  $75.00\nOpus 4 Fast  $30.00  $150.00\n\nCached (90% discount):\nHaiku cached $0.08   Sonnet cached $0.30\nOpus cached  $1.50   + cache_write tokens","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8003,"version":1,"versionNonce":8004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"pricing_table","lineHeight":1.25},

