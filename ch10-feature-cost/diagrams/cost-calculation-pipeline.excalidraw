    {"type":"text","id":"state_t","x":358,"y":250,"width":324,"height":60,"text":"Session Cost State (per-session):\n  totalCost, totalInputTokens, totalOutputTokens,\n  totalAPIDuration, totalDuration,\n  linesAdded, linesRemoved\n  → StoredCostState JSON → disk persist\n  → restore on --resume\n  → getKairosActive() / getUserMsgOptIn() affect thresholds","originalText":"Session Cost State (per-session):\n  totalCost, totalInputTokens, totalOutputTokens,\n  totalAPIDuration, totalDuration,\n  linesAdded, linesRemoved\n  → StoredCostState JSON → disk persist\n  → restore on --resume\n  → getKairosActive() / getUserMsgOptIn() affect thresholds","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":9003,"version":1,"versionNonce":9004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"state_diag","lineHeight":1.25},

