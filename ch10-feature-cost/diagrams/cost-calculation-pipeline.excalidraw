    {"type":"text","id":"insight_t","x":28,"y":330,"width":294,"height":58,"text":"Cost tracking is a COUNTER, not a ledger:\nEvery API call adds to session-level accumulators (cost-tracker.ts ref exports). CostThresholdDialog is the safety valve — it's the circuit breaker for money, not just for errors.","originalText":"Cost tracking is a COUNTER, not a ledger:\nEvery API call adds to session-level accumulators (cost-tracker.ts ref exports). CostThresholdDialog is the safety valve — it's the circuit breaker for money, not just for errors.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":9603,"version":1,"versionNonce":9604,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"insight","lineHeight":1.25}
