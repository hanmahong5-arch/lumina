    {
      "type": "text",
      "id": "l3_text",
      "x": -64,
      "y": 403,
      "width": 465,
      "height": 85,
      "text": "Trigger: \"Current path blocked, fallback needed\"\n         3x 529  Fast Mode rate-limited  model unavailable\n\nResponse: Model downgrade (Opus->Sonnet)\n          Fallback to standard speed  circuit breaker open\n\nComponent: fastMode.ts + model fallback",
      "originalText": "Trigger: \"Current path blocked, fallback needed\"\n         3x 529  Fast Mode rate-limited  model unavailable\n\nResponse: Model downgrade (Opus->Sonnet)\n          Fallback to standard speed  circuit breaker open\n\nComponent: fastMode.ts + model fallback",
      "fontSize": 10,
      "fontFamily": 3,
