    {
      "type": "text",
      "id": "insight_text",
      "x": 9,
      "y": 435,
      "width": 743,
      "height": 40,
      "text": "This is a circuit breaker pattern applied to the user experience -- when the fast path gets congested, gracefully fall back without user noticing a 'failure'.",
