    {"type":"text","id":"insight_text","x":168,"y":358,"width":545,"height":30,"text":"A project can define a custom MCP server that overrides the user's global config — team tooling wins.\nProject-level MCP → per-repo shared tools that every team member gets automatically.","originalText":"A project can define a custom MCP server that overrides the user's global config — team tooling wins.\nProject-level MCP → per-repo shared tools that every team member gets automatically.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8002,"version":1,"versionNonce":8003,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"insight_box","lineHeight":1.25}
