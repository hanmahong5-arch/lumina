    {"type":"text","id":"l5_text","x":215,"y":174,"width":290,"height":95,"text":"L5 — Remote (Claude.ai, innermost) ★\n\nfetchClaudeAIMcpConfigsIfEligible()\nfetched from cloud when user is\nClaude.ai subscriber\n\nscope = 'remote'\nhighest specificity overrides all","originalText":"L5 — Remote (Claude.ai, innermost) ★\n\nfetchClaudeAIMcpConfigsIfEligible()\nfetched from cloud when user is\nClaude.ai subscriber\n\nscope = 'remote'\nhighest specificity overrides all","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":6002,"version":1,"versionNonce":6003,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"l5","lineHeight":1.25},

