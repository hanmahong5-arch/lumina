    {"type":"text","id":"shtp_pro_list","x":474,"y":182,"width":190,"height":54,"text":"+ Bidirectional over single conn\n+ Resumable sessions\n+ Standard HTTP (auth, headers)\n+ Cloud-native, scalable\n+ Single URL scheme","originalText":"+ Bidirectional over single conn\n+ Resumable sessions\n+ Standard HTTP (auth, headers)\n+ Cloud-native, scalable\n+ Single URL scheme","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":4010,"version":1,"versionNonce":4011,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},
