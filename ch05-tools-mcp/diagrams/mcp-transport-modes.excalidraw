    {"type":"text","id":"sse_mech","x":246,"y":78,"width":195,"height":36,"text":"Mechanism: Server-Sent Events\n(HTTP streaming)\nSDK: SSEClientTransport\ndeprecated in MCP spec v2","originalText":"Mechanism: Server-Sent Events\n(HTTP streaming)\nSDK: SSEClientTransport\ndeprecated in MCP spec v2","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3004,"version":1,"versionNonce":3005,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
    {"type":"text","id":"sse_use","x":246,"y":122,"width":195,"height":34,"text":"Use case: HTTP-based MCP\nservers. Legacy remote servers\nbefore StreamableHTTP.","originalText":"Use case: HTTP-based MCP\nservers. Legacy remote servers\nbefore StreamableHTTP.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3006,"version":1,"versionNonce":3007,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
    {"type":"text","id":"sse_pro","x":246,"y":166,"width":60,"height":14,"text":"Pros:","originalText":"Pros:","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#48BB78","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3008,"version":1,"versionNonce":3009,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"sse_pro_list","x":246,"y":182,"width":190,"height":54,"text":"+ Simple HTTP\n+ Firewall-friendly (port 80/443)\n+ HTTP auth / headers / cookies\n  supported\n+ Good for server→client push","originalText":"+ Simple HTTP\n+ Firewall-friendly (port 80/443)\n+ HTTP auth / headers / cookies\n  supported\n+ Good for server→client push","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3010,"version":1,"versionNonce":3011,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},
    {"type":"text","id":"sse_con","x":246,"y":246,"width":60,"height":14,"text":"Cons:","originalText":"Cons:","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3012,"version":1,"versionNonce":3013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"sse_con_list","x":246,"y":262,"width":190,"height":54,"text":"- Unidirectional (server→client)\n  only — needs separate POST for\n  client→server requests\n- Two connections to manage\n- No resumability\n- Deprecated in MCP v2 spec","originalText":"- Unidirectional (server→client)\n  only — needs separate POST for\n  client→server requests\n- Two connections to manage\n- No resumability\n- Deprecated in MCP v2 spec","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3014,"version":1,"versionNonce":3015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},

