    {"type":"text","id":"note_text","x":18,"y":364,"width":655,"height":30,"text":"Transport Selection: ClaudeCode detects from config URL scheme:\n  no URL = stdio  |  url with http(s) = StreamableHTTP (preferred over SSE)\n  client.ts imports all three; selection logic in McpClientTransport.create()","originalText":"Transport Selection: ClaudeCode detects from config URL scheme:\n  no URL = stdio  |  url with http(s) = StreamableHTTP (preferred over SSE)\n  client.ts imports all three; selection logic in McpClientTransport.create()","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":5002,"version":1,"versionNonce":5003,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"note_box","lineHeight":1.3}
