    {"type":"text","id":"stdio_mech","x":18,"y":78,"width":195,"height":24,"text":"Mechanism: stdin/stdout pipe\nSDK: StdioClientTransport","originalText":"Mechanism: stdin/stdout pipe\nSDK: StdioClientTransport","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2004,"version":1,"versionNonce":2005,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
    {"type":"text","id":"stdio_use","x":18,"y":112,"width":195,"height":34,"text":"Use case: Local CLI tools\nsingle-process, subprocess\nspawning. Most common MCP\nsetup for local dev.","originalText":"Use case: Local CLI tools\nsingle-process, subprocess\nspawning. Most common MCP\nsetup for local dev.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2006,"version":1,"versionNonce":2007,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
    {"type":"text","id":"stdio_pro","x":18,"y":160,"width":60,"height":14,"text":"Pros:","originalText":"Pros:","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#48BB78","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2008,"version":1,"versionNonce":2009,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"stdio_pro_list","x":18,"y":176,"width":190,"height":54,"text":"+ Simple setup, no port config\n+ No network overhead\n+ Process lifecycle management\n  (parent exit = child exit)\n+ Works behind firewalls","originalText":"+ Simple setup, no port config\n+ No network overhead\n+ Process lifecycle management\n  (parent exit = child exit)\n+ Works behind firewalls","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2010,"version":1,"versionNonce":2011,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},
    {"type":"text","id":"stdio_con","x":18,"y":240,"width":60,"height":14,"text":"Cons:","originalText":"Cons:","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2012,"version":1,"versionNonce":2013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"stdio_con_list","x":18,"y":256,"width":190,"height":54,"text":"- No remote/MPC support\n- Process lifecycle bound\n  (no persistence across restarts)\n- ECONNRESET / EPIPE / bad JSON\n  — fragile on stderr leaks\n- Can't detect server crash","originalText":"- No remote/MPC support\n- Process lifecycle bound\n  (no persistence across restarts)\n- ECONNRESET / EPIPE / bad JSON\n  — fragile on stderr leaks\n- Can't detect server crash","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2014,"version":1,"versionNonce":2015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},

