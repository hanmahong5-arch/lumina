    {"type":"text","id":"shtp_use","x":474,"y":122,"width":195,"height":34,"text":"Use case: Modern MCP servers,\ncloud-hosted services.\nThis is the protocol to use.","originalText":"Use case: Modern MCP servers,\ncloud-hosted services.\nThis is the protocol to use.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":4006,"version":1,"versionNonce":4007,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
