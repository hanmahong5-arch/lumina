    {
      "type": "text",
      "id": "insight_t",
      "x": 17,
      "y": 318,
      "width": 670,
      "height": 35,
      "text": "BashTool is special — speculative execution is a security optimization that parallelism alone cannot provide.\nOther tools use pure concurrency (Promise.all dispatch). Bash needs pre-classification to save 200-500ms per cmd.",
