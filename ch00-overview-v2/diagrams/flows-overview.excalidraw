    {"type":"text","id":"flow_a_text","x":40,"y":182,"width":260,"height":145,"text":"Flow A: Bash Command Execution\n\n1. API Stream → BashTool.call()\n2. hasPermissionsToUseTool()\n3. deny / allow / YOLO-classify\n4. shell.exec() → tool_result\n\nBashTool.tsx","originalText":"Flow A: Bash Command Execution\n\n1. API Stream → BashTool.call()\n2. hasPermissionsToUseTool()\n3. deny / allow / YOLO-classify\n4. shell.exec() → tool_result\n\nBashTool.tsx","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40003,"version":1,"versionNonce":40004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"flow_a","lineHeight":1.25},

    {"type":"rectangle","id":"flow_b","x":530,"y":177,"width":280,"height":155,"strokeColor":"#00D4AA","backgroundColor":"#16213E","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50001,"version":1,"versionNonce":50002,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"flow_b_text","type":"text"},{"id":"arr_b","type":"arrow"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"flow_b_text","x":540,"y":182,"width":260,"height":145,"text":"Flow B: File Read+Edit (Two-Turn)\n\n1. Turn1: ReadTool → content\n2. next_turn continue →\n3. Turn2: EditTool → permission?\n4. applyEdit() → diff → result\n\ntoolExecution.ts","originalText":"Flow B: File Read+Edit (Two-Turn)\n\n1. Turn1: ReadTool → content\n2. next_turn continue →\n3. Turn2: EditTool → permission?\n4. applyEdit() → diff → result\n\ntoolExecution.ts","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50003,"version":1,"versionNonce":50004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"flow_b","lineHeight":1.25},

    {"type":"rectangle","id":"flow_c","x":30,"y":357,"width":280,"height":155,"strokeColor":"#FF6B6B","backgroundColor":"#2A1520","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":60001,"version":1,"versionNonce":60002,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"flow_c_text","type":"text"},{"id":"arr_c","type":"arrow"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"flow_c_text","x":40,"y":362,"width":260,"height":145,"text":"Flow C: Multi-Agent Dispatch\n\n1. AgentTool.call() trigger\n2. buildForkedMessages() clone\n3. runAgent() → child queryLoop\n4. results merge → parent continue\n\nrunAgent.ts","originalText":"Flow C: Multi-Agent Dispatch\n\n1. AgentTool.call() trigger\n2. buildForkedMessages() clone\n3. runAgent() → child queryLoop\n4. results merge → parent continue\n\nrunAgent.ts","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":60003,"version":1,"versionNonce":60004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"flow_c","lineHeight":1.25},

