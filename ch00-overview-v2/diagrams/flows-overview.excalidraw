    {"type":"text","id":"flow_d_text","x":540,"y":362,"width":260,"height":145,"text":"Flow D: Context Overflow Recovery\n\n1. 413/max_output_tokens trigger\n2. withhold error message\n3. collapse_drain / compact()\n4. state restore → retry\n\ncompact.ts","originalText":"Flow D: Context Overflow Recovery\n\n1. 413/max_output_tokens trigger\n2. withhold error message\n3. collapse_drain / compact()\n4. state restore → retry\n\ncompact.ts","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFFFFF","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":70003,"version":1,"versionNonce":70004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"flow_d","lineHeight":1.25},

