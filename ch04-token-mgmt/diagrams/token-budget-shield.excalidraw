    {"type":"rectangle","id":"layer2","x":120,"y":195,"width":560,"height":105,"strokeColor":"#FF6B6B","backgroundColor":"#2A1520","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300001,"version":1,"versionNonce":300002,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"l2t","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"l2t","x":150,"y":203,"width":500,"height":88,"text":"Layer 2: maxBudgetUsd\n---------------------------------------\nMeasures: Accumulated dollar cost of API calls\nAction:   Stop session when cost cap exceeded\nLocation: Cost tracker in billing/cost module\n\nPurpose: prevents unexpected financial charges","originalText":"Layer 2: maxBudgetUsd\n---------------------------------------\nMeasures: Accumulated dollar cost of API calls\nAction:   Stop session when cost cap exceeded\nLocation: Cost tracker in billing/cost module\n\nPurpose: prevents unexpected financial charges","fontSize":10,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FF6B6B","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300003,"version":1,"versionNonce":300004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"layer2","lineHeight":1.25},

