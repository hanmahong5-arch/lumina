    {"type":"text","id":"l3t","x":150,"y":343,"width":500,"height":88,"text":"Layer 3: Task Budget\n---------------------------------------\nMeasures: Per-task token usage with task-budgets header\nAction:   Reject task if token budget would be exceeded\nLocation: Task scheduler with beta headers\n\nPurpose: fine-grained control per individual task","originalText":"Layer 3: Task Budget\n---------------------------------------\nMeasures: Per-task token usage with task-budgets header\nAction:   Reject task if token budget would be exceeded\nLocation: Task scheduler with beta headers\n\nPurpose: fine-grained control per individual task","fontSize":10,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFB84D","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400003,"version":1,"versionNonce":400004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"layer3","lineHeight":1.25},

