    {"type":"text","id":"note_t","x":30,"y":465,"width":740,"height":25,"text":"Shield analogy: outer layer (turns) catches runaway loops first, middle layer (dollars) limits financial exposure,\ninner layer (task budget) provides fine-grained per-task control with beta headers.","originalText":"Shield analogy: outer layer (turns) catches runaway loops first, middle layer (dollars) limits financial exposure,\ninner layer (task budget) provides fine-grained per-task control with beta headers.","fontSize":10,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500003,"version":1,"versionNonce":500004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"note_box","lineHeight":1.25}
