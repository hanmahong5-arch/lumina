    {
      "type": "text",
      "id": "insight_text",
      "x": 28,
      "y": 327,
      "width": 700,
      "height": 31,
      "text": "Extraction is ASYNCHRONOUS — doesn't block UX. Fork agent is a sandboxed Sonnet that only reads/writes memory files, never the user's code.",
      "originalText": "Extraction is ASYNCHRONOUS — doesn't block UX. Fork agent is a sandboxed Sonnet that only reads/writes memory files, never the user's code.",
      "fontSize": 10,
