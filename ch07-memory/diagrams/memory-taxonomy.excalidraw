    {
      "type": "text",
      "id": "col3_text",
      "x": 330,
      "y": 60,
      "width": 110,
      "height": 171,
      "text": "Purpose:\nOngoing work goals,\ndecisions, trade-offs\n\nExample:\n\"auth middleware\nrewrite for compliance\"\n\"Q3 milestone: DB\nlayer refactor\"\n\nLifetime:\nShort-term, decays\nfast\n\nToken priority:\nVariable",
      "originalText": "Purpose:\nOngoing work goals,\ndecisions, trade-offs\n\nExample:\n\"auth middleware\nrewrite for compliance\"\n\"Q3 milestone: DB\nlayer refactor\"\n\nLifetime:\nShort-term, decays\nfast\n\nToken priority:\nVariable",
