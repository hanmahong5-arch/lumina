    {"type":"text","id":"filter_ex_text","x":38,"y":254,"width":265,"height":55,"text":"Filtered (BLOCKED):                Allowed (PASS):\n\"API key: sk-xxxxx\"  ->  BLOCKED    \"Use Linear board INGEST\"\n\"password in .env\"   ->  BLOCKED    \"Deploy needs 2 approvals\"\n\"token stored at X\"  ->  BLOCKED    \"DB migration planned Q3\"","originalText":"Filtered (BLOCKED):                Allowed (PASS):\n\"API key: sk-xxxxx\"  ->  BLOCKED    \"Use Linear board INGEST\"\n\"password in .env\"   ->  BLOCKED    \"Deploy needs 2 approvals\"\n\"token stored at X\"  ->  BLOCKED    \"DB migration planned Q3\"","fontSize":8.5,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#A0AEC0","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640011,"version":1,"versionNonce":640012,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"filter_example_box","lineHeight":1.25},

