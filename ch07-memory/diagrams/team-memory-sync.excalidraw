    {"type":"text","id":"insight_text","x":328,"y":255,"width":285,"height":55,"text":"Secret Guard is a PREVENTIVE content-level filter.\n\n\"API key stored in .env.local\" is CAUGHT\n—even though it doesn't contain the actual key.\nThe mention itself leaks that a secret exists there.","originalText":"Secret Guard is a PREVENTIVE content-level filter.\n\n\"API key stored in .env.local\" is CAUGHT\n—even though it doesn't contain the actual key.\nThe mention itself leaks that a secret exists there.","fontSize":9,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#FFB84D","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":650011,"version":1,"versionNonce":650012,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"insight_box","lineHeight":1.25}
